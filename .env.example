# Origine du backend Render (sans slash final, sans /api)
# Exemple: https://monpermis-api.onrender.com
# Laisser vide en local (le proxy Vite redirige /api et /uploads)
VITE_API_URL=

# Google OAuth — Web Client ID (Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=votre_web_client_id.apps.googleusercontent.com
