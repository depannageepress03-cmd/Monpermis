# Production (Render)
EXPO_PUBLIC_API_URL=https://monpermis-api.onrender.com

# Dev local (décommenter et commenter la ligne prod si besoin)
# EXPO_PUBLIC_API_URL=http://192.168.1.89:5000

# Google OAuth (IDs depuis Google Cloud Console)
# Web : obligatoire (id_token côté mobile + site web)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=votre_web_client_id.apps.googleusercontent.com
# Android : client OAuth Android (package com.monpermis.app + SHA-1 release/debug)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=votre_android_client_id.apps.googleusercontent.com
# iOS : client OAuth iOS (bundle com.monpermis.app)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=votre_ios_client_id.apps.googleusercontent.com
