PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/auto-ecole?retryWrites=true&w=majority
JWT_SECRET=changez_moi_secret_jwt_long_et_aleatoire

# URLs front (sans slash final)
CLIENT_URL=https://votre-site-apprenant.onrender.com
ADMIN_CLIENT_URL=https://votre-admin.onrender.com
# Origines CORS autorisées (séparées par des virgules). Inclure site + admin.
ALLOWED_ORIGINS=https://votre-site-apprenant.onrender.com,https://votre-admin.onrender.com

# URL publique de l’API (webhook FedaPay, docs)
API_PUBLIC_URL=https://votre-api.onrender.com

# Google OAuth (même Client ID Web que VITE_GOOGLE_CLIENT_ID côté site)
GOOGLE_CLIENT_ID=votre_web_client_id.apps.googleusercontent.com
# Optionnel : clients mobiles (même valeurs que EXPO_PUBLIC_GOOGLE_* côté app)
# GOOGLE_ANDROID_CLIENT_ID=votre_android_client_id.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=votre_ios_client_id.apps.googleusercontent.com

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=Monpermis.bj <noreply@monpermis.bj>

ALLOW_ADMIN_REGISTRATION=true

# FedaPay
FEDAPAY_PUBLIC_KEY=pk_live_xxx
FEDAPAY_SECRET_KEY=sk_live_xxx
FEDAPAY_ENVIRONMENT=live
FEDAPAY_WEBHOOK_SECRET=wh_live_xxx
# FEDAPAY_CALLBACK_URL=https://votre-site-apprenant.onrender.com/abonnement

# Limite API (requêtes / 15 min / IP). Défaut 900.
# API_RATE_LIMIT_MAX=900

MOBILE_SCHEME=monpermis

# Chat IA tuteur (cours Code) — clé Anthropic, jamais exposée au client
ANTHROPIC_API_KEY=
# Optionnel (défaut: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# WhatsApp Cloud API (rappels réservation). Sans credentials → log + lien wa.me en dev.
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Seed admin (optionnel, npm run seed:admin)
# ADMIN_PHONE=0147880143
# ADMIN_PASSWORD=changez_moi_8_car_min
# ADMIN_FULL_NAME=Administrateur
